---
interface Props {
  testimonials: any[];
}

const { testimonials } = Astro.props;
---
<div class="relative overflow-hidden group">
    <div class="flex transition-transform duration-700 ease-in-out" :style="`transform: translateX(-${currentTestimonial * 100}%)`">
        <template x-for="t in testimonials" :key="t.id">
            <div class="w-full flex-shrink-0 px-4">
                <div class="max-w-4xl 2xl:max-w-6xl mx-auto text-center">
                    <div class="mb-10 2xl:mb-16 inline-block relative">
                        <div class="absolute -top-6 -left-10 text-brand-sunset/20 text-9xl font-serif">“</div>
                        <img :src="t.img" :alt="t.name" class="w-24 h-24 2xl:w-32 2xl:h-32 rounded-full mx-auto object-cover border-2 border-brand-sunset p-1 grayscale group-hover:grayscale-0 transition-all duration-700" loading="lazy">
                    </div>
                    <blockquote class="text-2xl md:text-3xl 2xl:text-5xl font-serif font-light mb-10 2xl:mb-16 leading-relaxed italic text-base-content/90" x-text="t.quote"></blockquote>
                    <cite class="not-italic">
                        <span class="block text-brand-navy dark:text-white font-bold text-xl 2xl:text-3xl tracking-tight mb-2" x-text="t.name"></span>
                        <span class="text-brand-sunset uppercase tracking-[0.2em] text-xs 2xl:text-base font-bold" x-text="t.role"></span>
                    </cite>
                </div>
            </div>
        </template>
    </div>
    
    <div class="flex justify-center gap-4 mt-16 2xl:mt-24">
        <template x-for="(t, index) in testimonials" :key="index">
            <button @click="currentTestimonial = index" class="w-2.5 h-2.5 2xl:w-4 2xl:h-4 rounded-full transition-all duration-500" :class="currentTestimonial === index ? 'bg-brand-sunset w-10 2xl:w-16' : 'bg-base-300 hover:bg-brand-sunset/30'"></button>
        </template>
    </div>
</div>
