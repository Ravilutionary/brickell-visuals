---
interface Props {
  title: string;
  accent: string;
  description?: string;
  as?: 'h1' | 'h2';
}

const { title, accent, description, as: Tag = 'h2' } = Astro.props;
---
<div class="max-w-2xl 2xl:max-w-4xl mb-16 2xl:mb-24">
    <Tag class="text-4xl md:text-5xl 2xl:text-7xl font-serif font-bold text-brand-navy dark:text-white mb-6 uppercase tracking-tight">
        {title} <span class="text-brand-sunset italic font-normal lowercase">{accent}</span>
    </Tag>
    {description && (
        <p class="text-lg 2xl:text-2xl font-light text-base-content/70 leading-relaxed max-w-2xl">
            {description}
        </p>
    )}
</div>
