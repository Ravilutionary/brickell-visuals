---
interface Props {
  posts: any[];
}

const { posts } = Astro.props;
---
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 2xl:gap-12">
    {posts.map(post => (
        <article class:list={["group cursor-pointer", post.data.hideMobile ? "hidden md:block" : ""]}>
            <div class="overflow-hidden rounded-sm mb-6 aspect-video relative bg-base-300/30">
                <img src={post.data.img} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                <div class="absolute top-4 left-4 bg-brand-navy/90 backdrop-blur-sm text-white text-[10px] 2xl:text-xs font-bold px-3 py-1 uppercase tracking-widest">{post.data.cat}</div>
            </div>
            <h3 class="text-xl md:text-2xl 2xl:text-3xl font-serif font-bold group-hover:text-brand-sunset transition-colors mb-3">{post.data.title}</h3>
            <p class="text-base-content/70 font-light 2xl:text-lg mb-4 line-clamp-2">{post.data.desc}</p>
            <a href="#" class="inline-flex items-center text-sm 2xl:text-base font-bold uppercase tracking-widest text-brand-navy dark:text-brand-sunset hover:gap-2 transition-all">Read Journal <span class="ml-1">→</span></a>
        </article>
    ))}
</div>
