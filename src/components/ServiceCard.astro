---
interface Props {
  service: {
    id: string;
    title: string;
    price: string;
    desc: string;
    img: string;
    alt: string;
    highlight: boolean;
  };
}

import { Image } from 'astro:assets';

const { service } = Astro.props;
---
<div :id={`'${service.id}'`} class="group cursor-pointer scroll-mt-32 animate-fade-in-up" class:list={[service.highlight ? 'md:-mt-8' : '']}>
    <div class="overflow-hidden rounded-sm mb-6 aspect-[3/4] relative" class:list={[service.highlight ? 'shadow-2xl shadow-brand-sunset/10' : '']}>
        {service.highlight && <div class="absolute top-4 right-4 z-10 bg-brand-sunset/90 backdrop-blur-sm text-white text-xs font-bold px-4 py-1 uppercase tracking-widest">Most Booked</div>}
        <Image 
            src={service.img} 
            alt={service.alt} 
            width={600} 
            height={800}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
        />
        <div class="absolute inset-0 bg-brand-navy/0 group-hover:bg-brand-navy/20 transition-colors duration-500"></div>
    </div>
    <div class="text-center">
        <h3 class="text-2xl 2xl:text-3xl font-serif font-bold text-brand-navy dark:text-white mb-2">{service.title}</h3>
        <p class="text-base-content/70 mb-4 font-light 2xl:text-lg">{service.desc}</p>
        <p class="text-xl font-serif text-brand-sunset dark:text-brand-sunset italic">{service.price}</p>
    </div>
</div>
