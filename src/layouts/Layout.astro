---
import '../styles/global.css';

interface Props {
	title: string;
    description?: string;
}

const { title, description = "Fast 24hr Brickell portrait, product, real estate photography. Save 40% with bundled urban skyline sessions. Book now." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO & Social Meta -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://images.unsplash.com/photo-1503891450244-1f591465c6f1?auto=format&fit=crop&w=1200&q=80" />
		<meta name="twitter:card" content="summary_large_image" />
		
		<!-- Structured Data -->
		<script type="application/ld+json">
		{
		  "@context": "https://schema.org",
		  "@type": "LocalBusiness",
		  "name": "Brickell Triple-Threat Photography",
		  "image": "https://images.unsplash.com/photo-1503891450244-1f591465c6f1?auto=format&fit=crop&w=1200&q=80",
		  "@id": "https://brickellvisuals.com",
		  "url": "https://brickellvisuals.com",
		  "telephone": "+1-305-555-0199",
		  "address": {
			"@type": "PostalAddress",
			"streetAddress": "Brickell Ave",
			"addressLocality": "Miami",
			"addressRegion": "FL",
			"postalCode": "33131",
			"addressCountry": "US"
		  },
		  "priceRange": "$$$",
		  "sameAs": [
			"https://instagram.com/brickellvisuals",
			"https://linkedin.com/company/brickellvisuals"
		  ]
		}
		</script>
		
		<!-- GLightbox -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
	</head>
	<body 
		x-data="{ scrolled: false, dark: false }" 
		@scroll.window="scrolled = (window.pageYOffset > 50)" 
		:data-theme="dark ? 'dark' : 'light'" 
		:class="dark ? 'dark' : ''" 
		class="font-sans antialiased selection:bg-brand-sunset/30 transition-colors duration-500"
	>
		<slot />
	</body>
</html>
